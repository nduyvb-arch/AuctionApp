<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="0"
      style="-fx-background-color: #f8fafc;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controllers.AddItemViewController">

    <children>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #f8fafc;"
                    VBox.vgrow="ALWAYS">

            <content>
                <VBox spacing="18" style="-fx-padding: 24;">

                    <VBox spacing="6">
                        <children>
                            <Label text="Đăng sản phẩm mới" textFill="#0f172a">
                                <font>
                                    <Font name="System Bold" size="24" />
                                </font>
                            </Label>

                            <Label text="Nhập thông tin sản phẩm, chọn ảnh đại diện và gửi lên hệ thống đấu giá."
                                   textFill="#64748b" />
                        </children>
                    </VBox>

                    <VBox spacing="18"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #e2e8f0; -fx-border-radius: 18; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 14, 0, 0, 4);">

                        <children>
                            <GridPane hgap="18" vgap="16">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" />
                                    <ColumnConstraints percentWidth="50" />
                                </columnConstraints>

                                <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                </rowConstraints>

                                <children>
                                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <children>
                                            <Label text="Tên sản phẩm" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                                            <TextField fx:id="itemNameTextField"
                                                       prefHeight="40"
                                                       promptText="Ví dụ: iPhone 15 Pro Max"
                                                       style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <children>
                                            <Label text="Loại sản phẩm" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                                            <ComboBox fx:id="itemTypeComboBox"
                                                      prefHeight="40"
                                                      maxWidth="Infinity"
                                                      style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                                        <children>
                                            <Label text="Mô tả sản phẩm" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                                            <TextArea fx:id="itemDescriptionTextArea"
                                                      prefHeight="110"
                                                      promptText="Mô tả tình trạng, đặc điểm, phụ kiện đi kèm..."
                                                      wrapText="true"
                                                      style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                        <children>
                                            <Label text="Giá khởi điểm (VNĐ)" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                                            <TextField fx:id="startPriceTextField"
                                                       prefHeight="40"
                                                       promptText="Ví dụ: 1000000"
                                                       style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                        <children>
                                            <Label text="Bước giá tối thiểu (VNĐ)" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                                            <TextField fx:id="bidIncrementTextField"
                                                       prefHeight="40"
                                                       promptText="Ví dụ: 50000"
                                                       style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                        <children>
                                            <Label text="Thời gian đấu giá mặc định (phút)" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                                            <Spinner fx:id="durationSpinner"
                                                     prefHeight="40"
                                                     maxWidth="Infinity"
                                                     style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.rowSpan="2">
                                        <children>
                                            <Label text="Ảnh sản phẩm" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />

                                            <VBox alignment="CENTER"
                                                  prefHeight="170"
                                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 14; -fx-background-radius: 14; -fx-padding: 12;">
                                                <children>
                                                    <ImageView fx:id="imagePreview"
                                                               fitHeight="145"
                                                               fitWidth="230"
                                                               preserveRatio="true"
                                                               smooth="true" />
                                                </children>
                                            </VBox>

                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <children>
                                                    <Button fx:id="chooseImageButton"
                                                            text="Thêm ảnh"
                                                            onAction="#onChooseImageClicked"
                                                            prefHeight="38"
                                                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;" />

                                                    <Label fx:id="selectedImageLabel"
                                                           text="Chưa chọn ảnh"
                                                           textFill="#64748b"
                                                           wrapText="true" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </children>
                            </GridPane>

                            <Separator />

                            <Label fx:id="messageLabel" text="" style="-fx-font-size: 12;" />

                            <HBox spacing="12">
                                <children>
                                    <Button fx:id="submitItemButton"
                                            text="Đăng sản phẩm"
                                            onAction="#onSubmitItemClicked"
                                            prefHeight="42"
                                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;" />

                                    <Button fx:id="clearFormButton"
                                            text="Xóa form"
                                            onAction="#onClearFormClicked"
                                            prefHeight="42"
                                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
