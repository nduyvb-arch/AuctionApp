<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controllers.BidHistoryController"
      spacing="12"
      style="-fx-padding: 20; -fx-background-color: #f8fafc;"
      VBox.vgrow="ALWAYS">

    <children>
        <Label text="Lịch sử đấu giá của bạn"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />

        <HBox alignment="CENTER_LEFT"
              spacing="12"
              style="-fx-background-color: white;
                     -fx-padding: 14;
                     -fx-border-color: #e2e8f0;
                     -fx-border-radius: 10;
                     -fx-background-radius: 10;
                     -fx-border-width: 1;">

            <TextField fx:id="bidHistorySearchTextField"
                       prefHeight="38"
                       prefWidth="320"
                       promptText="Tìm kiếm sản phẩm..."
                       style="-fx-background-radius: 8;
                              -fx-border-color: #e2e8f0;
                              -fx-border-radius: 8;
                              -fx-background-color: white;
                              -fx-padding: 0 14;
                              -fx-font-size: 12;" />

            <ComboBox fx:id="bidHistoryStatusComboBox"
                      prefHeight="38"
                      prefWidth="155"
                      promptText="Lọc trạng thái..."
                      style="-fx-background-color: white;
                             -fx-border-color: #e2e8f0;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 0 10;" />

            <ComboBox fx:id="bidHistorySortComboBox"
                      prefHeight="38"
                      prefWidth="155"
                      promptText="Sắp xếp..."
                      style="-fx-background-color: white;
                             -fx-border-color: #e2e8f0;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 0 10;" />

            <HBox HBox.hgrow="ALWAYS" />

            <Button fx:id="bidHistoryRefreshButton"
                    mnemonicParsing="false"
                    onAction="#onBidHistoryRefreshClicked"
                    text="Làm mới"
                    prefHeight="38"
                    style="-fx-background-color: #3b82f6;
                           -fx-text-fill: white;
                           -fx-padding: 8 18;
                           -fx-font-size: 12;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-font-weight: bold;" />
        </HBox>

        <TableView fx:id="bidHistoryTable"
                   VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-border-color: #e2e8f0;
                          -fx-border-radius: 10;
                          -fx-background-radius: 10;
                          -fx-font-family: 'System';
                          -fx-font-size: 12;">

            <columns>
                <TableColumn fx:id="colItemName" text="Tên sản phẩm" prefWidth="220" />
                <TableColumn fx:id="colItemType" text="Loại" prefWidth="110" />
                <TableColumn fx:id="colBidAmount" text="Giá đặt" prefWidth="140" />
                <TableColumn fx:id="colBidTime" text="Thời gian" prefWidth="170" />
                <TableColumn fx:id="colAuctionStatus" text="Trạng thái" prefWidth="130" />
                <TableColumn fx:id="colResult" text="Kết quả" prefWidth="130" />
            </columns>
        </TableView>
    </children>
</VBox>