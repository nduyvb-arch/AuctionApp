<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controllers.BidHistoryController"
      spacing="10" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
    <children>
        <Label text="📊 Lịch sử đấu giá của bạn"
               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />

        <!-- Filter, Sort &amp; Search for Bid History -->
        <HBox alignment="CENTER" spacing="15.0"
              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-border-width: 1;">
            <TextField fx:id="bidHistorySearchTextField"
                       prefHeight="40.0" prefWidth="300.0"
                       promptText="🔍 Tìm kiếm sản phẩm..."
                       style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white; -fx-padding: 0 15; -fx-font-size: 12;" />
            <ComboBox fx:id="bidHistoryStatusComboBox"
                      prefHeight="40.0" prefWidth="150.0" promptText="Lọc trạng thái..."
                      style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 0 15;" />
            <ComboBox fx:id="bidHistorySortComboBox"
                      prefHeight="40.0" prefWidth="150.0" promptText="Sắp xếp..."
                      style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 0 15;" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button fx:id="bidHistoryRefreshButton"
                    mnemonicParsing="false" onAction="#onBidHistoryRefreshClicked"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-size: 12; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"
                    text="🔄 Làm mới" />
        </HBox>

        <!-- Bid History Table -->
        <TableView fx:id="bidHistoryTable" VBox.vgrow="ALWAYS"
                   style="-fx-font-family: 'System'; -fx-font-size: 11;">
            <columns>
                <TableColumn fx:id="colItemName"      text="Tên Sản Phẩm"  prefWidth="200" />
                <TableColumn fx:id="colItemType"      text="Loại"          prefWidth="100" />
                <TableColumn fx:id="colBidAmount"     text="Giá Đặt"       prefWidth="120" />
                <TableColumn fx:id="colBidTime"       text="Thời Gian"     prefWidth="150" />
                <TableColumn fx:id="colAuctionStatus" text="Trạng Thái"    prefWidth="120" />
                <TableColumn fx:id="colResult"        text="Kết Quả"       prefWidth="150" />
            </columns>
        </TableView>
    </children>
</VBox>
