<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controllers.MyItemsController"
      spacing="12"
      style="-fx-padding: 20; -fx-background-color: #f8fafc;"
      VBox.vgrow="ALWAYS">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <children>
                <Label text="Sản phẩm của tôi" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                <Label fx:id="myItemsSummaryLabel" text="Tổng: 0 sản phẩm"
                       style="-fx-background-color: #dbeafe; -fx-text-fill: #2563eb; -fx-padding: 5 10; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 11;" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-padding: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1;">
            <children>
                <TextField fx:id="myItemsSearchTextField" prefHeight="38" prefWidth="340"
                           promptText="Tìm kiếm sản phẩm của bạn..."
                           style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: white; -fx-padding: 0 14; -fx-font-size: 12;" />
                <ComboBox fx:id="myItemsStatusComboBox" prefHeight="38" prefWidth="155"
                          style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10;" />
                <ComboBox fx:id="myItemsSortComboBox" prefHeight="38" prefWidth="155"
                          style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10;" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button text="🔄 Làm mới" onAction="#onMyItemsRefreshClicked" prefHeight="38"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 18; -fx-font-size: 12; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: #f8fafc; -fx-padding: 0;">
            <content>
                <FlowPane fx:id="myItemsFlowPane" hgap="20" vgap="20" style="-fx-background-color: #f8fafc;">
                    <padding>
                        <Insets top="6" right="0" bottom="20" left="0" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
